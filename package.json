{
  "name": "turfbook",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "start:uat": "powershell -ExecutionPolicy Bypass -File start-uat.ps1",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "check:api-drift": "node scripts/check-api-drift.js",
    "check:api-drift:update": "node scripts/check-api-drift.js --update",
    "generate-api": "npx @openapitools/openapi-generator-cli generate -i turfbook-backend/src/main/resources/openapi/api.yaml -g typescript-axios -o src/api/generated --additional-properties=supportsES6=true,withInterfaces=true,npmName=turfbook-api-client",
    "build:apk": "eas build -p android --profile preview",
    "build:apk:local": "powershell -ExecutionPolicy Bypass -File build-apk-local.ps1",
    "build:apk:uat": "eas build -p android --profile uat",
    "build:apk:uat:local": "powershell -ExecutionPolicy Bypass -File build-apk-uat.ps1"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo/metro-runtime": "~3.2.3",
    "@react-native-community/netinfo": "11.3.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@tanstack/react-query": "^5.59.0",
    "axios": "^1.7.7",
    "eslint": "^8.57.1",
    "eslint-config-expo": "~7.1.2",
    "expo": "~51.0.28",
    "expo-build-properties": "~0.12.5",
    "expo-constants": "~16.0.2",
    "expo-dev-client": "~4.0.29",
    "expo-device": "~6.0.2",
    "expo-font": "~12.0.10",
    "expo-image-manipulator": "~12.0.5",
    "expo-image-picker": "~15.1.0",
    "expo-location": "~17.0.1",
    "expo-notifications": "~0.28.19",
    "expo-secure-store": "~13.0.2",
    "expo-status-bar": "~1.12.1",
    "expo-system-ui": "~3.0.7",
    "expo-updates": "~0.25.28",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-maps": "1.14.0",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@openapitools/openapi-generator-cli": "^2.13.4",
    "@types/react": "~18.2.79",
    "typescript": "~5.3.3"
  },
  "private": true
}
