{
  "expo": {
    "name": "TurfBook",
    "icon": "./assets/logo/icon.png",
    "slug": "turfbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo/splash.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#0FAE6E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "@react-native-google-signin/google-signin",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TurfBook uses your location to show nearby venues and distance.",
          "locationWhenInUsePermission": "TurfBook uses your location to show nearby venues and distance."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "TurfBook needs access to your photos to upload venue images."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.turfbook.app"
    },
    "androidStatusBar": {
      "backgroundColor": "#0FAE6E",
      "translucent": false,
      "barStyle": "light-content"
    },
    "android": {
      "package": "com.turfbook.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "d0109049-7875-444d-a5ce-eadddd586e79"
      }
    },
    "owner": "2124.programmer"
  }
}
