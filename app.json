{
  "expo": {
    "name": "Score-Adda",
    "slug": "turfbook",
    "scheme": "scoreadda",
    "version": "1.0.0",
    "newArchEnabled": false,
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/logo/icon.png",
    "description": "Score-Adda — a multi-sport turf and court booking platform.",
    "primaryColor": "#0FAE6E",
    "backgroundColor": "#FFFFFF",
    "platforms": ["ios", "android", "web"],
    "splash": {
      "image": "./assets/logo/splash.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#0FAE6E"
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Score-Adda uses your location to show nearby venues and distance.",
          "locationWhenInUsePermission": "Score-Adda uses your location to show nearby venues and distance."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Score-Adda needs access to your photos to upload venue and profile images.",
          "cameraPermission": "Score-Adda needs access to your camera to take venue and profile photos."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0FAE6E"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-asset"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.scoreadda.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Score-Adda needs access to your camera to take venue and profile photos.",
        "LSApplicationQueriesSchemes": ["whatsapp", "tel"]
      }
    },
    "android": {
      "package": "com.scoreadda.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo/icon.png",
        "backgroundColor": "#0FAE6E"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS",
        "READ_MEDIA_IMAGES"
      ]
    },
    "androidStatusBar": {
      "barStyle": "light-content",
      "backgroundColor": "#0FAE6E",
      "translucent": false
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/logo/icon.png",
      "name": "Score-Adda",
      "shortName": "Score-Adda",
      "description": "Score-Adda — book turfs & courts near you.",
      "themeColor": "#0FAE6E",
      "backgroundColor": "#FFFFFF",
      "display": "standalone"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "d0109049-7875-444d-a5ce-eadddd586e79"
      }
    },
    "owner": "2124.programmer"
  }
}