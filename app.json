{
  "expo": {
    "name": "TurfBook",
    "slug": "turfbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#0FAE6E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TurfBook uses your location to show nearby venues and distance.",
          "locationWhenInUsePermission": "TurfBook uses your location to show nearby venues and distance."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.turfbook.app"
    },
    "android": {
      "package": "com.turfbook.app",
      "versionCode": 1,
      "usesCleartextTraffic": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "apiBaseUrlAndroid": "http://10.0.2.2:8080",
      "apiBaseUrlIos": "http://localhost:8080",
      "apiBaseUrlWeb": "http://localhost:8080",
      "eas": {
        "projectId": "2bcdd95d-6e74-4e06-9ad5-0c9f0e64de32"
      }
    }
  }
}
